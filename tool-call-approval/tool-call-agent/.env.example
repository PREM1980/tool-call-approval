ANTHROPIC_API_KEY=your-api-key-here

# Seconds to wait for tool approval before auto-rejecting (default: 300)
# APPROVAL_TIMEOUT_SECONDS=300

# Postgres for agent/chat/session persistence (defaults to local Postgres on port 5432)
POSTGRES_URL=postgresql+psycopg2://localhost:5432/postgres

# Separate Postgres database for login, users, roles, and chat-session ownership.
# This must point at a different database name than POSTGRES_URL.
REGISTRATION_DATABASE_URL=postgresql+psycopg2://localhost:5432/registration

# JWT auth for the Angular UI/API gateway. Change the secret for shared environments.
JWT_SECRET_KEY=change-this-local-development-secret
JWT_ACCESS_TOKEN_MINUTES=480

# LLM provider: AWS (default), GCP, or LOCAL
LLM_PROVIDER=AWS

# AWS Bedrock (required when LLM_PROVIDER=AWS)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# Reports — S3 bucket where PDF reports are stored
REPORT_S3_BUCKET=your-report-bucket-name
# Presigned URL expiry in seconds (default: 3600 = 1 hour)
# REPORT_PRESIGNED_URL_EXPIRY=3600

# Vertex AI / Gemini (required when LLM_PROVIDER=GCP)
# Point to a GCP service account JSON key file on disk — never commit the file itself
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# OpenAI-compatible local/AIP endpoint (required when LLM_PROVIDER=LOCAL)
OPENAI_API_KEY=sk-your-local-endpoint-key
MODEL_ID=nemotron-3-super
BASE_URL=https://models.k8s.aip.mitre.org/v1
# Set false for internal endpoints with a self-signed certificate chain.
LOCAL_VERIFY_SSL=true
# Prefer this over LOCAL_VERIFY_SSL=false when you have the internal CA bundle.
# LOCAL_CA_BUNDLE=/path/to/internal-ca.pem
